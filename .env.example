# ─────────────────────────────────────────────────────────────────────────
# Kevin Conru — environment template. Copy to `.env.local` and fill in.
# (.env.local is gitignored; never commit real secrets.)
# ─────────────────────────────────────────────────────────────────────────

# Neon Postgres — single pooled connection string (used for runtime queries AND
# migrations). Modern Neon no longer exposes a separate direct/unpooled URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# DIRECT_URL is optional: set it only if you have an unpooled endpoint and want
# migrations to bypass the pooler. If unset, migrations use DATABASE_URL.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# NextAuth v5 — generate AUTH_SECRET with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="some secret"
AUTH_URL="http://localhost:3000"

# Initial admin (seeded by prisma/seed.ts). Change before deploying.
ADMIN_EMAIL="kevinconru@yahoo.com"
ADMIN_PASSWORD="change-me"

# Google Cloud Storage (media). Private key keeps escaped \n newlines.
GCS_PROJECT_ID=""
GCS_BUCKET_NAME=""
GCS_CLIENT_EMAIL=""
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
GCS_PUBLIC_URL_BASE="https://storage.googleapis.com"
